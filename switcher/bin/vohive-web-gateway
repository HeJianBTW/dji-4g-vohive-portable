#!/usr/bin/env python3
"""Small same-origin gateway that adds USB mode controls to VoHive."""
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from http.client import HTTPConnection
from urllib.parse import urlsplit
import json
import subprocess

BACKEND_HOST = "127.0.0.1"
BACKEND_PORT = 7576
MODE_SCRIPT = "/usr/local/sbin/vohive-usb-mode"

WIDGET = r'''
<style>
#vh-usb-page{position:fixed;z-index:9000;left:364px;top:82px;right:0;bottom:0;overflow:auto;background:#f9fafb;padding:40px;font-family:Inter,system-ui,sans-serif;color:#111827}
.dark #vh-usb-page{background:#101014;color:#f9fafb}#vh-usb-page .vh-card{max-width:760px;background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:28px;box-shadow:0 1px 3px #0001}
.dark #vh-usb-page .vh-card{background:#18181b;border-color:#333}#vh-usb-page h1{font-size:26px;margin:0 0 8px}#vh-usb-page p{color:#6b7280;margin:0 0 24px}.dark #vh-usb-page p{color:#a1a1aa}
#vh-usb-mode-status{padding:12px;border-radius:10px;background:#f3f4f6;font:13px ui-monospace,SFMono-Regular,monospace;margin-bottom:20px;word-break:break-word}.dark #vh-usb-mode-status{background:#27272a}
#vh-usb-page button{border:0;border-radius:9px;padding:10px 14px;margin-right:10px;cursor:pointer;font-weight:700;font-size:14px}#vh-usb-external{background:#4f46e5;color:#fff}#vh-usb-restore{background:#e5e7eb;color:#18181b}.dark #vh-usb-restore{background:#3f3f46;color:#fff}
#vh-usb-nav.vh-active{background:rgba(79,70,229,.13)!important;color:#6366f1!important;border-radius:12px}
</style>
<div id="vh-usb-page" hidden><div class="vh-card"><h1>USB 使用模式</h1><p>在 VoHive（QMI）与外接网卡（ECM）之间切换模块。不会修改 SIM、短信或代理配置。</p><div id="vh-usb-mode-status">正在读取状态…</div><button id="vh-usb-external">外接网卡模式</button><button id="vh-usb-restore">恢复 VoHive</button></div></div>
<script>
(()=>{const page=document.getElementById('vh-usb-page');const status=document.getElementById('vh-usb-mode-status');let open=false;
function find(t){return [...document.querySelectorAll('[role="menuitem"]')].find(e=>e.innerText.trim()===t)}
function rename(el,from,to){const w=document.createTreeWalker(el,NodeFilter.SHOW_TEXT);let n;while(n=w.nextNode())if(n.nodeValue.trim()===from){n.nodeValue=n.nodeValue.replace(from,to);return}}
function installNav(){if(document.getElementById('vh-usb-nav'))return true;const sys=find('系统设置'),log=find('实时日志');const ref=sys||log;if(!ref)return false;const item=ref.cloneNode(true);item.id='vh-usb-nav';item.classList.remove('is-active');rename(item,sys?'系统设置':'实时日志','USB 使用模式');item.addEventListener('click',e=>{e.preventDefault();open=true;show()});ref.parentNode.insertBefore(item,ref);return true}
async function refresh(){try{const r=await fetch('/__usb_mode/status');const j=await r.json();status.textContent=j.status}catch(e){status.textContent='状态暂不可用'}}
async function change(mode){const text=mode==='external'?'切到外接网卡模式后，VoHive 会暂停，随后可拔下模块。确定继续？':'模块插回服务器后将切回 QMI 并自动恢复 VoHive。确定继续？';if(!confirm(text))return;const r=await fetch('/__usb_mode/'+mode,{method:'POST',headers:{'Content-Type':'application/json'},body:'{}'});const j=await r.json();alert(j.message||'已发送切换指令');setTimeout(refresh,2500)}
function show(){installNav();page.hidden=!open;const nav=document.getElementById('vh-usb-nav');if(nav)nav.classList.toggle('vh-active',open);if(open)refresh()}
document.getElementById('vh-usb-external').onclick=()=>change('external');document.getElementById('vh-usb-restore').onclick=()=>change('vohive');
document.addEventListener('click',e=>{const item=e.target.closest('[role="menuitem"]');if(item&&item.id!=='vh-usb-nav'){open=false;show()}},true);
new MutationObserver(show).observe(document.getElementById('app'),{childList:true,subtree:true});setTimeout(show,300);})();
</script>
'''

FALLBACK = """<!doctype html><meta charset=utf-8><title>VoHive USB 模式</title>""" + WIDGET + """<main style='font-family:system-ui;padding:42px'><h2>VoHive 等待模块恢复</h2><p>模块插回服务器后，打开 USB 使用模式并点击“恢复 VoHive”。</p></main>"""

def mode_status():
    result = subprocess.run([MODE_SCRIPT, "status"], text=True, capture_output=True, timeout=8)
    return (result.stdout or result.stderr).strip()

class Gateway(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"
    def log_message(self, fmt, *args):
        print("%s - %s" % (self.address_string(), fmt % args), flush=True)

    def send_json(self, code, payload):
        data = json.dumps(payload, ensure_ascii=False).encode()
        self.send_response(code); self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data))); self.end_headers(); self.wfile.write(data)

    def handle_mode(self):
        if self.command == "GET" and self.path == "/__usb_mode/status":
            return self.send_json(200, {"status": mode_status()})
        if self.command != "POST": return self.send_json(405, {"message": "method not allowed"})
        mode = self.path.rsplit("/", 1)[-1]
        if mode not in ("external", "vohive"):
            return self.send_json(404, {"message": "unknown mode"})
        subprocess.Popen([MODE_SCRIPT, mode], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
        message = "正在切换到外接网卡模式；完成后即可拔下模块。" if mode == "external" else "正在恢复 QMI；模块重启后 VoHive 会自动上线。"
        return self.send_json(202, {"message": message})

    def forward(self):
        body = b""
        if self.headers.get("Content-Length"):
            body = self.rfile.read(int(self.headers["Content-Length"]))
        headers = {k:v for k,v in self.headers.items() if k.lower() not in {"host","connection","accept-encoding","content-length"}}
        headers["Host"] = f"{BACKEND_HOST}:{BACKEND_PORT}"
        try:
            conn = HTTPConnection(BACKEND_HOST, BACKEND_PORT, timeout=35)
            conn.request(self.command, self.path, body=body, headers=headers)
            resp = conn.getresponse()
            content_type = resp.getheader("Content-Type", "")
            if "text/event-stream" in content_type:
                self.send_response(resp.status, resp.reason)
                for k,v in resp.getheaders():
                    if k.lower() not in {"content-length", "connection", "transfer-encoding", "content-encoding"}:
                        self.send_header(k, v)
                self.end_headers()
                try:
                    while chunk := resp.read(4096):
                        self.wfile.write(chunk); self.wfile.flush()
                except (BrokenPipeError, ConnectionResetError):
                    pass
                return
            raw = resp.read()
            if "text/html" in content_type and self.path in ("/", ""):
                raw = raw.replace(b"</body>", WIDGET.encode() + b"</body>")
            self.send_response(resp.status, resp.reason)
            for k,v in resp.getheaders():
                if k.lower() not in {"content-length", "connection", "transfer-encoding", "content-encoding"}:
                    self.send_header(k, v)
            self.send_header("Content-Length", str(len(raw)))
            self.end_headers()
            if self.command != "HEAD": self.wfile.write(raw)
        except Exception:
            if self.command == "GET" and self.path in ("/", ""):
                data = FALLBACK.encode(); self.send_response(200); self.send_header("Content-Type", "text/html; charset=utf-8"); self.send_header("Content-Length", str(len(data))); self.end_headers()
                if self.command != "HEAD": self.wfile.write(data)
            else:
                self.send_json(503, {"message": "VoHive 正在等待模块或重启"})

    def do_GET(self):
        self.handle_mode() if self.path.startswith("/__usb_mode/") else self.forward()
    def do_HEAD(self): self.forward()
    def do_POST(self):
        self.handle_mode() if self.path.startswith("/__usb_mode/") else self.forward()
    def do_PUT(self): self.forward()
    def do_PATCH(self): self.forward()
    def do_DELETE(self): self.forward()
    def do_OPTIONS(self):
        self.send_response(204); self.send_header("Allow", "GET, HEAD, POST, PUT, PATCH, DELETE, OPTIONS"); self.end_headers()

ThreadingHTTPServer(("0.0.0.0", 7575), Gateway).serve_forever()
